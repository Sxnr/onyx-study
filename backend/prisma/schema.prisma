generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Crear tabla/colección de Usuarios 
model Usuario {
  id                  String      @id @default(uuid())
  nombre              String      
  email               String      @unique
  contrasena_hasheada String      
  nivel               Int         @default(1) 
  exp                 Int         @default(0) 
  
  // Relaciones
  documentos          Documento[]
  progresos           Progreso[]
  favoritos           Favorito[]
  hitos               Hito[]
}

// Crear tabla de Documentos 
model Documento {
  id             String   @id @default(uuid())
  propietario_id String   
  es_publico     Boolean  @default(false) 
  URL_archivo    String   
  titulo         String   
  etiquetas      String[] 

  // Relación con el usuario que lo subió
  propietario    Usuario  @relation(fields: [propietario_id], references: [id])

  // Timestamps (Necesario para que el Frontend ordene los archivos por fecha)
  createdAt      DateTime @default(now())
}

// Crear tabla de Desafíos 
model Desafio {
  id               String     @id @default(uuid())
  titulo           String
  descripcion      String
  nivel_dificultad String     // "Principiante", "Intermedio", "Avanzado"
  lenguaje         String     @default("universal")
  xp               Int        @default(100)
  codigo_inicial   String?    @db.Text
  casos_prueba     Json?      // Guardaremos los inputs y outputs esperados aquí
  createdAt        DateTime   @default(now())

  progresos        Progreso[]
}

// Crear tabla de Progreso 
model Progreso {
  id               String   @id @default(uuid())
  usuario_id       String
  desafio_id       String
  estado           String   // Ej: "Completado"
  fecha_completado DateTime @default(now())

  usuario          Usuario  @relation(fields: [usuario_id], references: [id])
  desafio          Desafio  @relation(fields: [desafio_id], references: [id])

  // Esto asegura que un usuario solo tenga un registro de progreso por cada desafío
  @@unique([usuario_id, desafio_id]) 
}

model RecursoPublico {
  id          String   @id @default(uuid())
  titulo      String
  descripcion String
  url         String
  categoria   String   // "Documentación", "Librería", "Curso", "CheatSheet"
  lenguaje    String   // "JavaScript", "Python", "General", etc.
  asignatura  String?   
  favoritoDe  Favorito[]
}

model Favorito {
  id                String         @id @default(uuid())
  usuario_id        String
  recurso_id        String
  usuario           Usuario        @relation(fields: [usuario_id], references: [id])
  recurso           RecursoPublico @relation(fields: [recurso_id], references: [id])

  @@unique([usuario_id, recurso_id])
}

// Agrega esto a tu archivo schema.prisma
model Hito {
  id        String   @id @default(uuid())
  ramo      String
  tipo      String
  fecha     String
  urgente   Boolean  @default(false)
  userId    String
  usuario   Usuario  @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}